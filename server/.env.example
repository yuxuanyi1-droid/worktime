PORT=3000
# 运行环境：development / production（影响日志格式、错误信息脱敏、seed 守卫）
NODE_ENV=development
# 必须替换为至少 32 字符的强随机密钥（可用 openssl rand -hex 32 生成）
JWT_SECRET=please-generate-a-strong-random-secret-at-least-32-chars-long
JWT_EXPIRES_IN=24h
DB_PATH=./data/worktime.db
# 生产环境务必保持 false；开发需自动同步表结构时设 true
TYPEORM_SYNCHRONIZE=false
# 信任的反向代理层数（取真实客户端 IP 用于限流/审计）。单层 Nginx=1，Cloudflare→Nginx→Node=2，直连=0
TRUST_PROXY=1
# 允许的前端源（逗号分隔），生产环境应锁定为真实域名。同时用于 CSP connectSrc
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 日志级别：trace/debug/info/warn/error/fatal
LOG_LEVEL=info
# /api/metrics 端点的 Bearer token；留空则不鉴权（生产强烈建议设置）
METRICS_TOKEN=
# 仅生产环境 seed 需设为 true 才允许执行（会生成随机强密码并强制首登改密）
ALLOW_PROD_SEED=false
