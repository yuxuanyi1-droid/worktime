# 注意：PORT（后端端口）统一在仓库根 .env 配置，此处不再保留，避免端口多处维护。
# 本文件仅配置后端业务相关的环境变量。

# 必须替换为至少 32 字符的强随机密钥（可用 openssl rand -hex 32 生成）
JWT_SECRET=please-generate-a-strong-random-secret-at-least-32-chars-long
JWT_EXPIRES_IN=24h
DB_PATH=./data/worktime.db
# 生产环境务必保持 false；开发需自动同步表结构时设 true
TYPEORM_SYNCHRONIZE=false
# 允许的前端源（逗号分隔），生产环境应锁定为真实域名。
# 未配置时后端会按根 .env 的 CLIENT_PORT 自动派生默认白名单
# （http://localhost:<CLIENT_PORT>,http://127.0.0.1:<CLIENT_PORT>）。
# 仅在需要锁定非默认来源时显式填写。
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==================== OIDC / 第三方登录（可选） ====================
# OIDC_PROVIDERS 以 JSON 形式定义所有第三方登录提供商的连接参数（单行书写）。
# key 是 provider id（如 authentik/dingtalk）。
#
# 哪些 provider 对用户可见，由管理员在「管理控制台 → 系统设置 → OIDC 认证」开关控制
# （存数据库 auth_oidc_enabled_providers）；此处只配「能连上哪些 provider」。
#
# 标准类型 type=oidc：issuer 指向 IdP 发现端点根（Authentik 形如
#   https://auth.example.com/application/o/<app-slug>/ ）。
# 钉钉类型 type=dingtalk：填 dingtalk.clientId/clientSecret。
#
# JIT 自动建号（jit:true）：适用于"企业主身份源"（如 Authentik）。登录时若该第三方账号
#   未绑定本地用户，自动创建本地用户（取 IdP 的 preferred_username/name/email/phone/department）
#   并绑定，无需管理员预先建号。每次登录还会同步 IdP 侧最新部门/组归属（按 department 字段
#   的 / 分隔路径自动创建/复用 Department + Group 层级树，员工调岗自动跟随）。
#   角色不自动同步——由本地管理员手动分配（可选 defaultRole 指定新用户默认角色，默认 employee）。
# 未设 jit 或 jit:false：补充登录方式，未绑定时提示"请先账号密码登录后绑定"（如钉钉）。
#
# 示例（实际使用时请压成一行）：
# OIDC_PROVIDERS={"authentik":{"enabled":true,"label":"Authentik","type":"oidc","jit":true,"defaultRole":"employee","issuer":"https://auth.example.com/application/o/worktime/","clientId":"xxx","clientSecret":"xxx","scopes":["openid","profile","email"]},"dingtalk":{"enabled":true,"label":"钉钉","type":"dingtalk","dingtalk":{"clientId":"dingxxxxxx","clientSecret":"xxxxxx"}}}
OIDC_PROVIDERS={"authentik":{"enabled":true,"label":"Authentik","type":"oidc","issuer":"https://sso.qinyuan.cloud/application/o/worktime/","clientId":"ZIKvqJ5gMvecmEHUNOPIQLnhWGhnwmyU0e37NEpz","clientSecret":"VdpUA2BqX1wWnIH7EADW2GXQ2uubAJjX4nNH7PCCi8aZxvjHQnpJAM5s28VMH6hdpRRHYlkpPMLYFQjU2jBoShyIQidPDZx7LqkPVzWAMa9DLNg3TxrxpDykaW4jYMmR","scopes":["openid","profile","email"],"groupRoleMap":{"admins":"admin","leaders":"group_leader"}}}
# state HMAC 签名密钥（授权码流程防 CSRF）；未配置时回退到 JWT_SECRET
# OIDC_STATE_SECRET=another-strong-random-secret
