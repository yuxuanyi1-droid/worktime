{
  "name": "worktime-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "seed": "tsx src/seed.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "worker:approval": "tsx src/approvalWorker.ts",
    "worker:approval:prod": "node dist/approvalWorker.js",
    "perf:inspect": "node scripts/inspect-perf-state.cjs",
    "perf:drill-approval-recovery": "node scripts/drill-approval-recovery.cjs",
    "perf:stress-reference-reads": "node scripts/stress-reference-reads.mjs",
    "migration:run": "tsx -e \"import './src/config/env'; import { AppDataSource } from './src/config/database'; void (async () => { await AppDataSource.initialize(); await AppDataSource.runMigrations(); await AppDataSource.destroy(); })();\"",
    "migration:revert": "tsx -e \"import './src/config/env'; import { AppDataSource } from './src/config/database'; void (async () => { await AppDataSource.initialize(); await AppDataSource.undoLastMigration(); await AppDataSource.destroy(); })();\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "openid-client": "^6.8.4",
    "pdfmake": "^0.2.10",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^6.0.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.1",
    "typebox": "^1.1.38",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "esbuild": "0.28.1"
  }
}
