{
  "name": "worktime-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "seed": "tsx src/seed.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "migration:run": "tsx -e \"import('./src/config/database').then(async m => { await m.AppDataSource.initialize(); await m.AppDataSource.runMigrations(); await m.AppDataSource.destroy(); })\"",
    "migration:revert": "tsx -e \"import('./src/config/database').then(async m => { await m.AppDataSource.initialize(); await m.AppDataSource.undoLastMigration(); await m.AppDataSource.destroy(); })\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "pdfmake": "^0.2.10",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.1",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/pino": "^7.0.4",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "esbuild": "0.28.1"
  }
}
