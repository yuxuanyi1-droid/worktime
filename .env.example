# ==================== 工时管理系统统一配置 ====================
# 复制本文件为 .env（根目录），按需修改。
# 所有配置集中在此文件（后端 server/ 和前端 client/ 共用）。

# ===== 运行环境 =====
# development / production（影响日志格式、错误脱敏、seed 守卫、前端静态服务）
NODE_ENV=development

# ===== 前后端端口（端口单一真相源，前后端/CORS/代理自动联动）=====
# 后端 API 服务端口（生产模式下前端静态文件也由这个端口服务）
PORT=3000
# 前端开发服务器端口（仅开发模式用，vite dev server）
CLIENT_PORT=5173

# ===== 后端安全配置 =====
# JWT 签名密钥（必须为强随机字符串，至少 16 字符；生产请用 32+ 字符随机密钥）
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# JWT 过期时间
JWT_EXPIRES_IN=24h

# ===== 数据库 =====
# 数据库类型：sqlite（默认，零配置单文件）或 postgres（生产，高并发）
DB_TYPE=sqlite

# SQLite 配置（DB_TYPE=sqlite 时使用）
DB_PATH=./data/worktime.db

# PostgreSQL 配置（DB_TYPE=postgres 时使用）
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your-password
# DB_DATABASE=worktime
# DB_SSL=false

# 开发阶段设 true 让 TypeORM 自动同步新实体表结构（生产必须为 false）
TYPEORM_SYNCHRONIZE=true

# ===== 业务配置 =====
# 是否强制首次登录改密：生产保持默认 true（安全），开发调试设 false 可跳过
FORCE_CHANGE_PASSWORD=false

# ===== 子路径部署（可选）=====
# 留空 = 根路径部署；设为 /worktime 等 = 子路径部署（前后端同前缀）
# BASE_PATH=/worktime

# ===== CORS（可选）=====
# 允许的前端源（逗号分隔）。未配置时按 CLIENT_PORT 自动派生默认白名单。
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== 生产环境 seed 守卫 =====
# 生产环境（NODE_ENV=production）运行 seed 需要 ALLOW_PROD_SEED=true
# ALLOW_PROD_SEED=true

# ===== OIDC / 第三方登录（可选）=====
# 以 JSON 形式定义所有 OIDC 提供商的连接参数（单行书写）。
# key 是 provider id（如 authentik/dingtalk）。
# type=oidc: 标准OIDC（issuer/clientId/clientSecret/scopes）
#   jit:true = 主登录方式（首次登录自动建号+同步部门层级，需配 Property Mapping 暴露 phone/department）
#   jit:false/未设 = 补充登录（需先绑定）
# type=dingtalk: 非标准OAuth2（dingtalk.clientId/clientSecret）
# label = 登录页按钮显示文字
# OIDC_PROVIDERS={"authentik":{"enabled":true,"label":"Authentik","type":"oidc","jit":true,"defaultRole":"employee","issuer":"https://auth.example.com/application/o/worktime/","clientId":"xxx","clientSecret":"xxx","scopes":["openid","profile","email"]},"dingtalk":{"enabled":true,"label":"钉钉","type":"dingtalk","dingtalk":{"clientId":"dingxxxxxx","clientSecret":"xxxxxx"}}}
