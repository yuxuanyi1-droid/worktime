# ==================== 工时管理系统统一配置 ====================
# 复制本文件为 .env（根目录），按需修改。
# 所有配置集中在此文件（后端 server/ 和前端 client/ 共用）。

# ===== 运行环境 =====
# development / production（影响日志格式、错误脱敏、seed 守卫、前端静态服务）
NODE_ENV=development

# ===== 前后端端口（端口单一真相源，前后端/CORS/代理自动联动）=====
# 后端 API 服务端口（生产模式下前端静态文件也由这个端口服务）
PORT=3000
# 生产环境默认仅监听本机（由 Caddy/Nginx 对外）；容器部署可显式设为 0.0.0.0
API_HOST=127.0.0.1
# 单个 JSON/表单请求体上限；大文件应走专用上传链路
HTTP_BODY_LIMIT=1mb
# 前端开发服务器端口（仅开发模式用，vite dev server）
CLIENT_PORT=5173

# ===== 后端安全配置 =====
# JWT 签名密钥（必须为强随机字符串，至少 16 字符；生产请用 32+ 字符随机密钥）
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# JWT 过期时间
JWT_EXPIRES_IN=24h

# ===== 数据库 =====
# 当前项目统一使用 PostgreSQL；SQLite 已弃用
DB_TYPE=postgres

# PostgreSQL 配置（DB_TYPE=postgres 时使用）
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your-password
# DB_DATABASE=worktime
# DB_SSL=false
# 当前三 API 部署每实例使用 16；独立审批 worker 另计连接预算
# DB_POOL_MAX=16

# Redis（可选；配置后限流跨进程共享，submissionGroupId 用 INCR）
# REDIS_URL=redis://127.0.0.1:6379
# JWT 鉴权快照缓存（秒）；改密、登出、用户变更会主动失效
# AUTH_CACHE_TTL_SEC=60
# 组织目录缓存保持较短兜底；项目与审批配置有主动失效，可使用更长 TTL
# ORG_CACHE_TTL_SEC=60
# PROJECT_CACHE_TTL_SEC=300
# APPROVAL_FLOW_CACHE_TTL_SEC=300
# SETTING_CACHE_TTL_SEC=300
# 审批 Stream 未确认任务超过该时间后允许其他 worker 接管（毫秒）
# APPROVAL_CLAIM_IDLE_MS=30000
# 多 API 实例建议仅入队，并单独启动 npm run worker:approval:prod；4 核环境 worker 建议 DB_POOL_MAX=6
# APPROVAL_WORKER=0
# APPROVAL_BATCH_SIZE=50
# 成功 HTTP 请求日志采样比例（0=关闭，0.01=1%，1=全量）；4xx/5xx 始终记录
# HTTP_SUCCESS_LOG_SAMPLE_RATE=0.01
# 登录限流只累计失败请求；办公网共用出口时可按安全策略调整（默认 100 / 10 分钟）
# LOGIN_RATE_MAX=200

# 开发阶段设 true 让 TypeORM 自动同步新实体表结构（生产必须为 false）
TYPEORM_SYNCHRONIZE=false

# ===== 业务配置 =====
# 是否强制首次登录改密：生产保持默认 true（安全），开发调试设 false 可跳过
FORCE_CHANGE_PASSWORD=false

# ===== 子路径部署（可选）=====
# 留空 = 根路径部署；设为 /worktime 等 = 子路径部署（前后端同前缀）
# BASE_PATH=/worktime

# ===== CORS（可选）=====
# 允许的前端源（逗号分隔）。未配置时按 CLIENT_PORT 自动派生默认白名单。
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 生产指标接口必须设置；未设置时 /api/metrics 返回 404
# METRICS_TOKEN=replace-with-a-long-random-token

# ===== 生产环境 seed 守卫 =====
# 生产环境（NODE_ENV=production）运行 seed 需要 ALLOW_PROD_SEED=true
# ALLOW_PROD_SEED=true

# ===== OIDC / 第三方登录（可选）=====
# OIDC 回调允许的前端来源（逗号分隔）；未设置时复用 ALLOWED_ORIGINS
# OIDC_REDIRECT_ORIGINS=https://worktime.example.com
# 以 JSON 形式定义所有 OIDC 提供商的连接参数（单行书写）。
# key 是 provider id（如 authentik/dingtalk/siam）。
# type=oidc: 标准OIDC（issuer/clientId/clientSecret/scopes）
#   jit:true = 主登录方式（首次登录自动建号+同步部门层级，需配 Property Mapping 暴露 phone/department）
#   jit:false/未设 = 补充登录（需先绑定）
# type=dingtalk: 非标准OAuth2（dingtalk.clientId/clientSecret）
# type=siam: OPPO SIAM 直连OAuth2（clientId/clientSecret/ssoBaseUrl；推荐 jit:false 绑定模式）
#   ssoBaseUrl 默认 https://sso.myoas.com，dev/测试环境可覆盖
#   jit:false 时：用户必须先用账号密码登录后在「个人信息」绑定 SIAM，绑定后才能用 SIAM 登录
# label = 登录页按钮显示文字
# OIDC_PROVIDERS={"authentik":{"enabled":true,"label":"Authentik","type":"oidc","jit":true,"defaultRole":"employee","issuer":"https://auth.example.com/application/o/worktime/","clientId":"xxx","clientSecret":"xxx","scopes":["openid","profile","email"]},"dingtalk":{"enabled":true,"label":"钉钉","type":"dingtalk","dingtalk":{"clientId":"dingxxxxxx","clientSecret":"xxxxxx"}},"siam":{"enabled":true,"label":"OPPO SIAM","type":"siam","jit":false,"clientId":"ai_test_rca","clientSecret":"xxxxxx","ssoBaseUrl":"https://sso.myoas.com"}}

# ===== AI 助手配置（pi agent，可选）=====
# 不配置则右下角悬浮助手不可用，其他功能不受影响。
#
# 【快速选型】看你的 LLM 服务说什么协议：
#   - Anthropic Messages 协议（POST /v1/messages）             → AI_PROVIDER=custom + AI_API_TYPE=anthropic-messages
#   - OpenAI Chat Completions 协议（POST /v1/chat/completions） → AI_PROVIDER=custom + AI_API_TYPE=openai-completions
#
# 推荐统一用 AI_PROVIDER=custom：
#   - custom 能让 AI_API_TYPE 真正生效（openai/anthropic 内置 provider 会强制用 responses/messages 协议，忽略 AI_API_TYPE）
#   - custom 适合绝大多数第三方/兼容服务（Ollama、DeepSeek、智谱、OneAPI、vLLM、各类聚合网关等）
#
# AI_PROVIDER：anthropic | openai | custom（兼容服务推荐 custom）
AI_PROVIDER=custom
#
# AI_API_KEY：LLM 的 API key（必填，否则助手不可用）
AI_API_KEY=
#
# AI_BASE_URL：endpoint 地址（custom 时必填）
#   ⚠️ 重要：OpenAI 兼容服务通常要带 /v1 后缀！
#     Ollama 云:  https://ollama.com/v1
#     DeepSeek:   https://api.deepseek.com/v1
#     智谱 GLM:   https://open.bigmodel.cn/api/paas/v4
#     OneAPI:     http://your-oneapi:3000/v1
#   不带 /v1 会导致 pi 请求到错误路径返回 404。
AI_BASE_URL=
#
# AI_API_TYPE：API 协议（custom 时必填，否则默认 openai-completions）
#   anthropic-messages | openai-completions | openai-responses
AI_API_TYPE=openai-completions
#
# AI_MODEL：模型 id（按你的服务实际支持的模型名填）
#   Ollama 示例: gemma3:12b / qwen3-coder:480b（注意：部分模型如 deepseek-v4-flash/glm-4.7 是推理模型，
#                会把内容放非标准 reasoning 字段导致 pi 解析失败，建议选非推理模型如 gemma3）
AI_MODEL=gemma3:12b
#
# AI_MODEL_NAME：展示名（可选）
# AI_CONTEXT_WINDOW：上下文窗口，默认 128000
# AI_MAX_TOKENS：单次最大输出 token，默认 16384

# AI_MODEL_NAME：展示名（可选）
# AI_CONTEXT_WINDOW：上下文窗口，默认 128000
# AI_MAX_TOKENS：单次最大输出 token，默认 16384
