{
	admin off
	auto_https off
}

# 工时系统统一入口。API 实例仍保留完整 /worktime 路径，无需改应用路由。
http://127.0.0.1:3001 {
	encode zstd gzip

	reverse_proxy 127.0.0.1:3011 127.0.0.1:3012 127.0.0.1:3013 {
		lb_policy least_conn

		health_uri /worktime/api/health
		health_interval 10s
		health_timeout 2s
		health_status 200
		fail_duration 30s
		max_fails 2
		lb_try_duration 2s
		lb_try_interval 100ms
	}
}
